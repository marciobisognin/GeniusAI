# Frontend
VITE_BRIDGE_URL=http://localhost:4000

# Nirvana Bridge
NIRVANA_BRIDGE_HOST=127.0.0.1
NIRVANA_BRIDGE_PORT=4000

# URL pública do bridge usada para montar links de artefato (opcional). Se
# vazio, o bridge usa o header Host da própria requisição.
PUBLIC_BRIDGE_URL=

# --- Tudo abaixo já tem um padrão que funciona sem editar nada -------------
# Deixe em branco (ou remova a linha) para explorar a cena 3D e o roteamento
# sem depender de uma instalação do Nirvana OS (Opção A do README):
#   - IFFAR_ORG_CHART_PATH / IFFAR_ROUTING_PATH  -> os YAMLs versionados em
#     businesses/iffar/
#   - NIRVANA_ENGINE_PATH                        -> tools/stub-engine.ts,
#     que só grava um result.md de exemplo (não orquestra nada de verdade)
#   - IFFAR_TICKETS_DIR / IFFAR_OUTPUTS_DIR       -> .data/tickets e
#     .data/outputs, criados automaticamente na primeira execução
#
# Para orquestrações reais (Opção B), aponte para a sua instalação do
# Nirvana OS:
# NIRVANA_ENGINE_PATH=/caminho/para/brief-business.ts
# IFFAR_TICKETS_DIR=/caminho/para/businesses/iffar/tickets
# IFFAR_OUTPUTS_DIR=/caminho/para/businesses/iffar/outputs

# Enriquecimento opcional dos tooltips (resumo de competência por artigo do
# Anexo I). Também já tem padrão (businesses/iffar/competencias.yaml).
IFFAR_COMPETENCIAS_PATH=
