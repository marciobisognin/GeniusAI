{
  "name": "geniusai-civilizations",
  "private": true,
  "version": "0.0.0",
  "description": "Watchable AI — simulação de civilizações com agentes autônomos acionados por CLI de agente (Claude Code / Codex / opencode) ou Ollama.",
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "packages/shared"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "doctor": "node scripts/doctor.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:backend": "npm run dev --workspace apps/backend",
    "dev:frontend": "npm run dev --workspace apps/frontend",
    "health": "npm run health --workspace apps/backend",
    "test": "npm run test --workspace apps/backend",
    "e2e": "node e2e/smoke.mjs",
    "build": "npm run build --workspace apps/frontend",
    "typecheck": "npm run typecheck --workspace packages/shared && npm run typecheck --workspace apps/backend && npm run typecheck --workspace apps/frontend",
    "lint": "eslint .",
    "test:coverage": "npm run test:coverage --workspace apps/backend"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "playwright": "^1.49.0",
    "typescript-eslint": "^8.63.0"
  }
}
