# Runner de agente: claude | codex | opencode | ollama | mock
# ("mock" = decisões determinísticas sem LLM — ideal para desenvolver a UI e testar)
RUNNER=claude

# Override do binário do CLI (opcional). Ex.: um caminho absoluto.
# AGENT_CMD=claude

# Modelo (usado pelo runner ollama; e por CLIs que aceitem seleção de modelo)
MODEL=qwen2.5:14b

# Ollama (usado quando RUNNER=ollama)
OLLAMA_HOST=http://localhost:11434

# Endereço/porta do backend (HTTP + WebSocket). HOST padrão: 127.0.0.1 (só local).
HOST=127.0.0.1
PORT=8787

# Origins de browser extras aceitas no WebSocket (localhost já é aceito).
# ALLOWED_ORIGINS=http://192.168.0.10:5173

# Diretório de dados (saves/traces/memória). Padrão: ./data
# DATA_DIR=

# Narrador de eventos (1 chamada extra de LLM por tick)
NARRATOR=false

# Semente do mundo (define o gameId padrão: game-<seed>)
SEED=42

# Velocidade e timeouts
TICK_SPEED_MS=2000
TURN_TIMEOUT_MS=60000
# ASK_TIMEOUT_MS=30000
